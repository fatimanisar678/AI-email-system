## Choose which LLM to use for extraction
## Options: claude | gemini
## If not set, backend auto-picks based on which key is present.
LLM_PROVIDER=

## Claude (Anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=4000

## Gemini (Google)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TEMPERATURE=0.2

